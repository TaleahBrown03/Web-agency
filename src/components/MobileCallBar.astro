---
import { PHONE_DISPLAY, PHONE_HREF } from '../data/pricing';
---

<div
  class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 gap-2 border-t border-slate-800 bg-slate-950/95 p-3 backdrop-blur-lg md:hidden"
  style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom));"
>
  <a
    href={PHONE_HREF}
    class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-slate-600 bg-slate-900/60 px-4 py-3 text-sm font-bold text-slate-100 active:scale-95"
  >
    Call {PHONE_DISPLAY}
  </a>
  <a
    href="/contact"
    class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-emerald-500 to-cyan-500 px-4 py-3 text-sm font-bold text-slate-950 active:scale-95"
  >
    Book Now
  </a>
</div>
