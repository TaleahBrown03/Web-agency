---
const services = ["Recurring Home Cleaning", "Move-In / Move-Out", "Commercial Maintenance"];
const pricing = [
  { name: "Apartment", price: "$129", detail: "Studio to 2-bedroom refresh" },
  { name: "Standard Home", price: "$189", detail: "3-bedroom home with kitchen and bath focus" },
  { name: "Deep Clean", price: "$279", detail: "Top-to-bottom reset for seasonal or post-event needs" }
];
---

<div class="min-h-screen bg-emerald-50 text-emerald-950">
  <header class="border-b border-emerald-200/80 bg-white/80 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-8">
      <a href="/" class="text-lg font-semibold tracking-[0.28em] text-emerald-800">ORANGE COUNTY CLEANING</a>
      <nav class="hidden items-center gap-8 text-sm font-medium text-emerald-800 md:flex">
        <a href="#services" class="transition hover:text-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 active:text-emerald-700">Services</a>
        <a href="#pricing" class="transition hover:text-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 active:text-emerald-700">Pricing</a>
        <a href="#contact" class="transition hover:text-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 active:text-emerald-700">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="mx-auto grid max-w-7xl gap-12 px-6 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-28">
      <div class="space-y-8">
        <div class="inline-flex items-center rounded-full border border-emerald-300/80 bg-white px-4 py-2 text-sm font-medium text-emerald-700 shadow-sm">
          Trusted by busy households across Orange County
        </div>
        <div class="space-y-5">
          <h1 class="max-w-3xl text-4xl font-black leading-tight tracking-tight text-emerald-950 sm:text-5xl lg:text-6xl">
            Flawless House & Commercial Cleaning in Orange County
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-emerald-800/80">
            Reliable, detail-driven cleaning services for homes, offices, and short-term rentals with the calm consistency you expect from a premium local team.
          </p>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="#contact" class="inline-flex items-center justify-center rounded-full bg-emerald-700 px-7 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-700/20 transition duration-300 hover:-translate-y-0.5 hover:bg-emerald-800 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-emerald-50 active:scale-[0.99]">
            Get a Free Quote
          </a>
          <a href="#pricing" class="inline-flex items-center justify-center rounded-full border border-emerald-300 bg-white px-7 py-3 text-sm font-semibold text-emerald-800 transition duration-300 hover:-translate-y-0.5 hover:border-emerald-500 hover:bg-emerald-50 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-emerald-50 active:scale-[0.99]">
            View Pricing
          </a>
        </div>
        <div id="services" class="flex flex-wrap gap-3 pt-2">
          {services.map((service) => (
            <span class="rounded-full border border-emerald-200 bg-white/80 px-4 py-2 text-sm font-medium text-emerald-700">
              {service}
            </span>
          ))}
        </div>
      </div>

      <div class="rounded-[2rem] border border-emerald-200 bg-white p-8 shadow-[0_30px_120px_-40px_rgba(6,95,70,0.35)]">
        <div class="space-y-6">
          <div class="rounded-2xl border border-emerald-100 bg-emerald-50 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-600">Why clients choose us</p>
            <p class="mt-3 text-xl font-semibold text-emerald-950">Eco-conscious products, punctual crews, and spotless results on every visit.</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl border border-emerald-100 bg-white p-5">
              <p class="text-sm font-semibold text-emerald-700">Same-week availability</p>
              <p class="mt-2 text-sm text-emerald-800/80">Flexible scheduling for homes, offices, and post-event resets.</p>
            </div>
            <div class="rounded-2xl border border-emerald-100 bg-white p-5">
              <p class="text-sm font-semibold text-emerald-700">Insured & vetted staff</p>
              <p class="mt-2 text-sm text-emerald-800/80">Professional crews with transparent communication and reliable arrival windows.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="pricing" class="mx-auto max-w-7xl px-6 pb-24 lg:px-8">
      <div class="mb-10 space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-600">Transparent pricing</p>
        <h2 class="text-3xl font-semibold text-emerald-950 sm:text-4xl">Flat-rate options for every property size</h2>
      </div>
      <div class="grid gap-6 lg:grid-cols-3">
        {pricing.map((item) => (
          <div class="rounded-[1.75rem] border border-emerald-200 bg-white p-8 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-600">{item.name}</p>
            <p class="mt-4 text-4xl font-black text-emerald-950">{item.price}</p>
            <p class="mt-3 text-sm leading-7 text-emerald-800/80">{item.detail}</p>
            <a href="#contact" class="mt-8 inline-flex items-center justify-center rounded-full border border-emerald-300 px-5 py-2.5 text-sm font-semibold text-emerald-800 transition duration-300 hover:bg-emerald-50 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 active:scale-[0.99]">
              Schedule Service
            </a>
          </div>
        ))}
      </div>
    </section>
  </main>

  <footer id="contact" class="border-t border-emerald-200 bg-white/90">
    <div class="mx-auto flex flex-col gap-6 px-6 py-10 text-center text-sm text-emerald-800/80 lg:flex-row lg:items-center lg:justify-between lg:px-8">
      <p>Serving Orange County, NY with dependable cleaning support for every schedule.</p>
      <a href="tel:+18454459268" class="inline-flex items-center justify-center rounded-full bg-emerald-700 px-6 py-3 font-semibold text-white transition duration-300 hover:bg-emerald-800 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 active:scale-[0.99]">
        Call (845) 445-9268
      </a>
    </div>
  </footer>
</div>
