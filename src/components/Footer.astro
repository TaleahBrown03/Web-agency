---
// Footer.astro - Premium footer with Orange County Webworks branding
import { PHONE_DISPLAY as phoneNumber, PHONE_HREF as phoneHref } from '../data/pricing';

const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-slate-800/50 bg-slate-950/80 backdrop-blur-sm py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 sm:grid-cols-3">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <svg class="h-10 w-10 flex-shrink-0" viewBox="0 0 48 48" aria-hidden="true">
            <defs>
              <linearGradient id="logo-ring-footer" x1="4" y1="4" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                <stop offset="0" stop-color="#22d3ee" />
                <stop offset="0.5" stop-color="#10b981" />
                <stop offset="1" stop-color="#8b5cf6" />
              </linearGradient>
            </defs>
            <circle cx="24" cy="24" r="19" fill="none" stroke="url(#logo-ring-footer)" stroke-width="3.5" />
            <path d="M13 18 L17.5 32 L24 20 L30.5 32 L35 18" stroke="url(#logo-ring-footer)" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <div>
            <p class="text-xs font-bold bg-gradient-to-r from-cyan-300 to-emerald-300 bg-clip-text text-transparent">ORANGE COUNTY</p>
            <p class="text-lg font-bold text-slate-50">Webworks</p>
          </div>
        </div>
        <p class="text-sm text-slate-400 mt-3">
          Custom web engineering & automation systems for Orange County, NY businesses.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-bold text-slate-100 mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/services" class="text-slate-400 transition hover:text-emerald-400">Services</a>
          </li>
          <li>
            <a href="/locations" class="text-slate-400 transition hover:text-emerald-400">Areas We Serve</a>
          </li>
          <li>
            <a href="/portfolio" class="text-slate-400 transition hover:text-emerald-400">Portfolio</a>
          </li>
          <li>
            <a href="/about" class="text-slate-400 transition hover:text-emerald-400">About</a>
          </li>
          <li>
            <a href="/contact" class="text-slate-400 transition hover:text-emerald-400">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-bold text-slate-100 mb-4">Let's Talk</h4>
        <a
          href={phoneHref}
          class="inline-flex items-center gap-2 rounded-xl border border-slate-600 px-4 py-2 text-sm font-semibold text-slate-100 transition hover:border-emerald-400 hover:text-emerald-400 hover:bg-emerald-500/5"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {phoneNumber}
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-slate-800/50 pt-8 flex flex-col gap-3 text-center sm:flex-row sm:items-center sm:justify-between sm:text-left">
      <p class="text-xs text-slate-400">
        © {currentYear} Orange County Webworks. All rights reserved. Software Developer | Astro & Tailwind Engineers.
      </p>
      <a href="/privacy" class="text-xs text-slate-400 transition hover:text-emerald-400">Privacy Policy</a>
    </div>
  </div>
</footer>
