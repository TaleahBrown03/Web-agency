---
// ContactForm.astro - Premium Two-Column Contact & Consultation Booking System
// Left Column: Operational Contact Form with Service Tiers
// Right Column: Live Calendar Scheduling Interface
import { PRICING_TIERS, PHONE_DISPLAY, PHONE_HREF } from '../data/pricing';
---

<section id="contact" class="relative py-24 sm:py-40">
  <!-- Background gradients -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute -top-64 right-1/4 h-96 w-96 rounded-full bg-emerald-500/5 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -bottom-64 left-1/3 h-96 w-96 rounded-full bg-cyan-500/5 blur-3xl" aria-hidden="true"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-16 space-y-6 text-center">
      <h2 class="text-5xl font-bold text-slate-50 sm:text-6xl">Let's Build Your Growth Engine</h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">Choose your preferred way to connect: submit your project details or lock in a discovery call directly on my calendar.</p>
    </div>

    <!-- Two-Column Layout: Form + Calendar Booking -->
    <div class="grid gap-8 lg:grid-cols-2">
      
      <!-- LEFT COLUMN: Contact Form -->
      <div class="flex flex-col">
        <!-- Quick Call CTA -->
        <div class="mb-8 rounded-2xl border border-emerald-500/30 bg-emerald-500/5 p-6">
          <p class="text-sm font-semibold text-emerald-300 mb-2">
            PREFER TO TALK RIGHT NOW?
          </p>
          <a href={PHONE_HREF} class="text-2xl font-bold text-emerald-300 hover:opacity-80 transition">
            {PHONE_DISPLAY}
          </a>
          <p class="mt-3 text-sm text-slate-400">
            Call anytime for an immediate free consultation. I respond to messages within 24 hours.
          </p>
        </div>

        <!-- Contact Form Container -->
        <div class="rounded-2xl border border-slate-700/50 bg-gradient-to-br from-slate-900/50 to-slate-800/30 p-8 backdrop-blur-sm flex-1 flex flex-col">
          <h3 class="text-2xl font-bold text-slate-50 mb-6">Send Your Project Details</h3>

          <div id="formSuccess" class="hidden flex-1 flex-col items-center justify-center text-center py-12">
            <svg class="h-14 w-14 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h4 class="mt-4 text-xl font-bold text-slate-50">Thanks — got your project details.</h4>
            <p class="mt-2 text-slate-400">I'll respond within 24 hours with a customized proposal.</p>
          </div>

          <form id="contactForm" class="space-y-5 flex-1 flex flex-col" action="https://formspree.io/f/xgogwzyg" method="POST">
            
            <!-- Your Name Field -->
            <div>
              <label for="visitor_name" class="block text-sm font-semibold text-slate-300 mb-2">
                Your Name <span class="text-emerald-400">*</span>
              </label>
              <input
                type="text"
                id="visitor_name"
                name="visitor_name"
                required
                placeholder="John Smith"
                class="w-full rounded-lg border border-slate-600/50 bg-slate-900/50 px-4 py-2.5 text-slate-100 placeholder-slate-600 transition focus:border-emerald-400 focus:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-400/30 hover:border-slate-500"
              />
            </div>

            <!-- Business Email Field -->
            <div>
              <label for="email" class="block text-sm font-semibold text-slate-300 mb-2">
                Business Email <span class="text-emerald-400">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="hello@yourbusiness.com"
                class="w-full rounded-lg border border-slate-600/50 bg-slate-900/50 px-4 py-2.5 text-slate-100 placeholder-slate-600 transition focus:border-emerald-400 focus:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-400/30 hover:border-slate-500"
              />
            </div>

            <!-- Business Name Field -->
            <div>
              <label for="business_name" class="block text-sm font-semibold text-slate-300 mb-2">
                Business Name <span class="text-emerald-400">*</span>
              </label>
              <input
                type="text"
                id="business_name"
                name="business_name"
                required
                placeholder="Your Business LLC"
                class="w-full rounded-lg border border-slate-600/50 bg-slate-900/50 px-4 py-2.5 text-slate-100 placeholder-slate-600 transition focus:border-emerald-400 focus:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-400/30 hover:border-slate-500"
              />
            </div>

            <!-- Phone Number Field -->
            <div>
              <label for="phone" class="block text-sm font-semibold text-slate-300 mb-2">
                Phone Number <span class="text-emerald-400">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                placeholder="(845) 555-0123"
                class="w-full rounded-lg border border-slate-600/50 bg-slate-900/50 px-4 py-2.5 text-slate-100 placeholder-slate-600 transition focus:border-emerald-400 focus:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-400/30 hover:border-slate-500"
              />
            </div>

            <!-- Service Tier Dropdown -->
            <div>
              <label for="service_tier" class="block text-sm font-semibold text-slate-300 mb-2">
                Select Your Service Tier <span class="text-emerald-400">*</span>
              </label>
              <select
                id="service_tier"
                name="service_tier"
                required
                class="w-full rounded-lg border border-slate-600/50 bg-slate-900/50 px-4 py-2.5 text-slate-100 transition focus:border-emerald-400 focus:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-400/30 hover:border-slate-500 appearance-none cursor-pointer"
              >
                <option value="">Choose a service tier...</option>
                {PRICING_TIERS.map((tier) => (
                  <option value={tier.id}>{tier.name} - {tier.price} one-time</option>
                ))}
              </select>
            </div>

            <!-- Project Description Textarea -->
            <div class="flex-1 flex flex-col">
              <label for="message" class="block text-sm font-semibold text-slate-300 mb-2">
                Tell me about your project <span class="text-emerald-400">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                placeholder="What services does your business offer? What are your main goals? Any specific features or automations you need?"
                class="w-full flex-1 rounded-lg border border-slate-600/50 bg-slate-900/50 px-4 py-2.5 text-slate-100 placeholder-slate-600 transition focus:border-emerald-400 focus:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-400/30 hover:border-slate-500 resize-none"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              id="contactSubmit"
              class="w-full mt-2 rounded-lg bg-gradient-to-r from-emerald-500 to-cyan-500 px-6 py-3 text-base font-bold text-slate-950 shadow-lg shadow-emerald-500/30 transition duration-300 hover:shadow-xl hover:shadow-emerald-500/50 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2 focus:ring-offset-slate-950 active:scale-95 disabled:opacity-60 disabled:hover:scale-100"
            >
              Send Project Details →
            </button>

            <!-- Error Note (shown only if submission fails) -->
            <p id="formError" class="hidden text-xs text-red-400 text-center">
              Something went wrong sending that — please try again or call me directly.
            </p>

            <!-- Privacy Note -->
            <p class="text-xs text-slate-400 text-center">
              Secure submission. I'll respond within 24 hours with a customized proposal.
            </p>
          </form>
        </div>
      </div>

      <!-- RIGHT COLUMN: Calendar Scheduling -->
      <div class="flex flex-col">
        <!-- Calendar Header -->
        <div class="mb-8 space-y-3">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-900/40 border border-cyan-500/30 w-fit">
            <span class="text-sm font-semibold text-cyan-300">SCHEDULE A FREE DISCOVERY CALL</span>
          </div>
          <h3 class="text-2xl font-bold text-slate-50">
            Pick Your Strategy Session
          </h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            Available <span class="font-semibold text-emerald-300">Monday through Friday, 8am–5pm</span> for phone or video consultations. Select a time block below to lock in your dedicated strategy session.
          </p>
        </div>

        <!-- Calendar Container: live Cal.com embed -->
        <div class="rounded-2xl border border-slate-700/50 bg-gradient-to-br from-slate-900/50 to-slate-800/30 p-2 backdrop-blur-sm flex-1 flex flex-col overflow-hidden">
          <iframe
            src="https://cal.com/taleah-egxicz?theme=dark"
            class="w-full flex-1 min-h-[600px] rounded-xl"
            style="border: 0;"
            loading="lazy"
            title="Schedule a discovery call"
          ></iframe>
        </div>
      </div>
    </div>

    <!-- Trust Badges Section -->
    <div class="mt-16 grid gap-6 sm:grid-cols-3">
      <div class="flex items-start gap-3 rounded-lg border border-slate-700/30 bg-slate-900/20 p-4">
        <div class="mt-1">
          <svg class="h-5 w-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h4 class="font-semibold text-slate-100 text-sm">24-Hour Response</h4>
          <p class="text-xs text-slate-400 mt-1">All inquiries answered within one business day</p>
        </div>
      </div>

      <div class="flex items-start gap-3 rounded-lg border border-slate-700/30 bg-slate-900/20 p-4">
        <div class="mt-1">
          <svg class="h-5 w-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h4 class="font-semibold text-slate-100 text-sm">Free Consultation</h4>
          <p class="text-xs text-slate-400 mt-1">No obligation, no upsell — just strategy</p>
        </div>
      </div>

      <div class="flex items-start gap-3 rounded-lg border border-slate-700/30 bg-slate-900/20 p-4">
        <div class="mt-1">
          <svg class="h-5 w-5 text-violet-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h4 class="font-semibold text-slate-100 text-sm">Your Data is Secure</h4>
          <p class="text-xs text-slate-400 mt-1">Encrypted submissions, never shared or sold</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const form = document.getElementById('contactForm');
    const successBox = document.getElementById('formSuccess');
    const errorNote = document.getElementById('formError');
    const submitButton = document.getElementById('contactSubmit');
    if (!(form instanceof HTMLFormElement) || !successBox || !errorNote || !(submitButton instanceof HTMLButtonElement)) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      errorNote.classList.add('hidden');
      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (response.ok) {
          form.classList.add('hidden');
          successBox.classList.remove('hidden');
          successBox.classList.add('flex');
        } else {
          throw new Error('Form submission failed');
        }
      } catch {
        errorNote.classList.remove('hidden');
        submitButton.disabled = false;
        submitButton.textContent = 'Send Project Details →';
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initContactForm);
  document.addEventListener('astro:after-swap', initContactForm);
</script>
