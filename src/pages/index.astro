---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import LiveDemos from '../components/LiveDemos.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
---

<Layout title="Orange County Webworks | Custom Websites & Automation for Orange County Businesses">
  <Navigation />
  <main id="main-content" class="pb-20 md:pb-0">
    <Hero />
    <LiveDemos />
    <About />
    <div class="-mt-16 mb-16 text-center">
      <a href="/about" class="inline-block text-sm font-semibold text-emerald-300 hover:underline">Read the full story &amp; how a project works →</a>
    </div>
    <Services />
    <FAQ />
    <section class="relative py-16 text-center">
      <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight text-slate-50 sm:text-4xl mb-4">Ready to Get Started?</h2>
        <p class="text-slate-300 mb-8">
          Send your project details, book a free discovery call, or just call directly — all on the contact page.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-emerald-500 to-cyan-500 px-8 py-4 text-lg font-bold text-slate-950 shadow-2xl shadow-emerald-500/30 transition hover:shadow-emerald-500/50 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2 focus:ring-offset-slate-950 active:scale-95"
        >
          Get In Touch
        </a>
      </div>
    </section>
  </main>
  <Footer />
  <MobileCallBar />
</Layout>
