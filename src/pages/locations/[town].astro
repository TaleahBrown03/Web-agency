---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import MobileCallBar from '../../components/MobileCallBar.astro';
import PageHero from '../../components/PageHero.astro';
import { PHONE_DISPLAY, PHONE_HREF } from '../../data/pricing';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((location) => ({
    params: { town: location.id },
    props: { location },
  }));
}

const { location } = Astro.props;
const { data } = location;
const { Content } = await render(location);
---

<Layout title={data.seoTitle} description={data.seoDescription}>
  <Navigation />
  <main id="main-content" class="pb-20 md:pb-0">
    <PageHero
      eyebrow={data.region}
      title={`Web Design & Local SEO for ${data.name}, NY`}
      subtitle={data.character}
    />

    <section class="relative py-8">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="space-y-4 text-lg leading-relaxed text-slate-300 [&_p]:mb-4">
          <Content />
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          {data.industries.map((industry: string) => (
            <span class="rounded-full border border-slate-700/50 bg-slate-900/40 px-4 py-2 text-sm text-slate-300">{industry}</span>
          ))}
        </div>

        <div class="mt-12 text-center">
          <a
            href={PHONE_HREF}
            class="inline-block px-8 py-3 rounded-lg font-semibold bg-emerald-500/10 border border-emerald-400/50 text-emerald-300 hover:bg-emerald-500/20 hover:border-emerald-400 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-emerald-400"
          >
            Call {PHONE_DISPLAY}
          </a>
          <p class="mt-4 text-sm text-slate-400">
            Or see <a href="/services" class="text-emerald-300 hover:underline">all services</a> or the full <a href="/locations" class="text-emerald-300 hover:underline">list of areas we serve</a>.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <MobileCallBar />
</Layout>
