---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import PageHero from '../components/PageHero.astro';
import LiveDemos from '../components/LiveDemos.astro';
---

<Layout title="Portfolio | Orange County Webworks" description="Live, interactive demo builds showing what Orange County Webworks delivers at each package tier — for cleaning, HVAC, and auto/tire businesses.">
  <Navigation />
  <main id="main-content" class="pb-20 md:pb-0">
    <PageHero
      eyebrow="Portfolio"
      title="See the Work Before You Call"
      subtitle="These are self-built demo sites — not client work, since Orange County Webworks is just getting started — but they're fully live, fast-loading builds that show exactly what each package tier includes."
    />
    <LiveDemos />
  </main>
  <Footer />
  <MobileCallBar />
</Layout>
