---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import MobileCallBar from '../../components/MobileCallBar.astro';
import PageHero from '../../components/PageHero.astro';
import Services from '../../components/Services.astro';
---

<Layout title="Web Design | Orange County Webworks" description="Custom-coded Starter, Growth, and Automated website builds for Orange County, NY businesses — no templates, no bloat.">
  <Navigation />
  <main id="main-content" class="pb-20 md:pb-0">
    <PageHero
      eyebrow="Web Design"
      title="Custom-Coded Sites, From a Single Page to a Full Automated Build"
      subtitle="Every site is hand-written — no WordPress, no Squarespace, no page-builder templates. That means faster load times, cleaner code for Google to crawl, and a site that's actually yours."
    />

    <section class="relative py-8">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 space-y-6 text-slate-300 leading-relaxed">
        <p>
          Whichever package fits your business, the build process is the same: we talk through what your business does and who your customers are, I design and code the site around that, you review it before it goes live, and then it's yours.
        </p>
        <p>
          Below are the three tiers — pick the one that matches your business size, or call and we'll figure out the right fit together.
        </p>
      </div>
    </section>

    <Services />
  </main>
  <Footer />
  <MobileCallBar />
</Layout>
